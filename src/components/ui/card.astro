---
import { Image } from 'astro:assets'

const { img, author, title, text } = Astro.props
---

<div class="bg-white flex flex-col gap-2 rounded-lg overflow-hidden">
  <Image
    class="w-full h-48 object-cover object-center"
    src={img}
    alt={title}
    loading="eager"
  />
  <div class="flex flex-col p-8">
    <h2 class="text-sm text-gray-400">{author}</h2>
    <h1 class="text-lg text-black">{title}</h1>
    <p class="text-base text-gray-500">
      {text}
    </p>
  </div>
</div>
